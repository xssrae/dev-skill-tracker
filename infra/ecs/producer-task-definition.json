{
  "family": "dev-skill-tracker-producer",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::<account-id>:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "producer-service",
      "image": "<account-id>.dkr.ecr.us-east-1.amazonaws.com/dev-skill-tracker-producer:latest",
      "essential": true,
      "portMappings": [{ "containerPort": 8081, "protocol": "tcp" }],
      "environment": [
        { "name": "KAFKA_BOOTSTRAP_SERVERS", "value": "<msk-or-kafka-endpoint>:9092" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/dev-skill-tracker",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "producer"
        }
      }
    }
  ]
}
